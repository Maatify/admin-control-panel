				<div
					class="logo text-center text-xl font-bold whitespace-nowrap flex items-center gap-2 justify-center  dark:text-gray-100">


					<!-- MAATIFY Logo -->

					<svg class="size-6 text-black  dark:text-white ml-2 transition-all duration-300" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 316.93668 320.99997">
