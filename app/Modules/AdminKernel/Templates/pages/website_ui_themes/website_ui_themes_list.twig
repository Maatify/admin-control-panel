{% extends "layouts/base.twig" %}

{% block title %}
    Website UI Themes | {{ ui.appName }}
{% endblock %}

{% block content %}
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Website UI Themes Management</h2>

        <nav>
            <ol class="flex items-center gap-1.5">
                <li>
                    <a class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="{{ ui.adminUrl }}dashboard">
                        Home
                        <svg class="stroke-current" width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M6.0765 12.667L10.2432 8.50033L6.0765 4.33366" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </li>
                <li class="text-sm text-gray-800 dark:text-gray-200">Website UI Themes</li>
            </ol>
        </nav>
    </div>

    <script>
        window.websiteUiThemesCapabilities = {
            can_create: {{ capabilities.can_create ?? false ? 'true' : 'false' }},
            can_update: {{ capabilities.can_update ?? false ? 'true' : 'false' }},
            can_delete: {{ capabilities.can_delete ?? false ? 'true' : 'false' }}
        };
    </script>

    <div class="px-0 py-2">
        <div class="container lg:max-w-[100%] mt-6">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
                <form id="website-ui-themes-filter-form" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label for="filter-id" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Theme ID</label>
                            <input type="number" id="filter-id" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" placeholder="e.g., 1" min="1"/>
                        </div>

                        <div>
                            <label for="filter-entity-type" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Entity Type</label>
                            <input type="text" id="filter-entity-type" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" placeholder="e.g., product" maxlength="50"/>
                        </div>

                        <div>
                            <label for="filter-theme-file" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Theme File</label>
                            <input type="text" id="filter-theme-file" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" placeholder="e.g., product_custom.twig" maxlength="255"/>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3 pt-4">
                        <button type="submit" class="px-3 py-1 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors font-medium">Search</button>
                        <button type="button" id="website-ui-themes-reset-filters" class="px-3 py-1 bg-gray-200 text-sm dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium">Reset</button>

                        {% if capabilities.can_create %}
                            <button type="button" id="btn-create-website-ui-theme" class="ml-auto px-3 py-1 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 transition-colors font-medium">Create Theme</button>
                        {% endif %}
                    </div>
                </form>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-4">
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" id="website-ui-themes-search" class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" placeholder="Quick search by entity type, theme file, or display name..."/>
                    <button type="button" id="website-ui-themes-search-btn" class="px-3 py-1 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700 transition-colors font-medium">Search</button>
                    <button type="button" id="website-ui-themes-clear-search" class="px-3 py-1 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium">Clear</button>
                </div>
            </div>

            <div id="table-container" class="w-full"></div>
        </div>
    </div>

    <div id="website-ui-theme-modal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-opacity-70 z-50 flex items-center justify-center hidden">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center sticky top-0 bg-white dark:bg-gray-800 z-10">
                <h3 id="website-ui-theme-modal-title" class="text-lg font-semibold text-gray-800 dark:text-gray-100">Website UI Theme Details</h3>
                <button type="button" class="close-modal text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <svg class="w-6 h-6 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-6">
                <form id="website-ui-theme-form" class="space-y-4">
                    <input type="hidden" id="theme-id">

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Entity Type</label>
                        <input type="text" id="theme-entity-type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" maxlength="50" required>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Theme File</label>
                        <input type="text" id="theme-theme-file" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" maxlength="255" required>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Display Name</label>
                        <input type="text" id="theme-display-name" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100" maxlength="150" required>
                    </div>
                </form>
            </div>
            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex justify-end gap-3 sticky bottom-0 bg-white dark:bg-gray-800">
                <button type="button" class="close-modal px-4 py-2 bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200 transition-colors">Cancel</button>
                <button type="button" id="btn-save-website-ui-theme" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">Save</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('assets/maatify/admin-kernel/js/api_handler.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/callback_handler.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/Input_checker.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/data_table.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/select2.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/admin-ui-components.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/admin-page-bridge.js') }}"></script>

    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/website-ui-themes/website-ui-themes-helpers-v2.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/website-ui-themes/website-ui-themes-with-components-v2.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/website-ui-themes/website-ui-themes-modals-v2.js') }}"></script>
    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/website-ui-themes/website-ui-themes-actions-v2.js') }}"></script>
{% endblock %}
