{% extends "layouts/base.twig" %}

{% block title %}My Profile{% endblock %}

{% block content %}
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6 mt-4 mx-2">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">My Profile</h2>
        <nav>
            <ol class="flex items-center gap-1.5">
                <li>
                    <a class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="{{ ui.adminUrl }}dashboard">
                        Home
                        <svg class="stroke-current" width="17" height="16" viewbox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M6.0765 12.667L10.2432 8.50033L6.0765 4.33366" stroke="" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                    </a>
                </li>
                <li class="text-sm text-gray-800 dark:text-gray-200">My Profile</li>
            </ol>
        </nav>
    </div>

    <!-- Overview Card -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm dark:bg-gray-800 dark:border-gray-700 mx-2 mb-6">
        <div class="flex border-b border-gray-200 dark:border-gray-700 px-6 py-4 items-center justify-between">
            <h3 class="text-lg font-medium text-gray-800 dark:text-gray-200">Personal Information</h3>
            <div class="flex gap-2">
                <a href="{{ ui.adminUrl }}me/password" class="py-2 px-3 inline-flex justify-center items-center gap-2 rounded-md border font-medium bg-white text-gray-700 shadow-sm align-middle hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-blue-600 transition-all text-sm dark:bg-gray-800 dark:hover:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:text-white dark:focus:ring-offset-gray-800">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    Change Password
                </a>
            </div>
        </div>

        <div class="p-6">
            <dl class="grid sm:grid-cols-2 gap-4 gap-y-6">
                <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Display Name</dt>
                    <dd class="mt-1 text-base text-gray-900 dark:text-gray-200">{{ profile.admin.display_name ?? 'N/A' }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</dt>
                    <dd class="mt-1">
                        {% if profile.admin.status == 'ACTIVE' %}
                            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-500">
                                Active
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-500">
                                {{ profile.admin.status|capitalize }}
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Primary Email</dt>
                    <dd class="mt-1 text-base text-gray-900 dark:text-gray-200 flex items-center gap-2">
                        {{ profile.email.masked_address }}
                        {% if profile.email.verification_status == 'VERIFIED' %}
                            <span title="Verified at {{ profile.email.verified_at }}" class="text-blue-600 dark:text-blue-500">
                                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                </svg>
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Account Created</dt>
                    <dd class="mt-1 text-base text-gray-900 dark:text-gray-200">{{ profile.admin.created_at }}</dd>
                </div>
            </dl>
        </div>
    </div>
{% endblock %}
