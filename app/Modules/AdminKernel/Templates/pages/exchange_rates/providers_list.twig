{% extends "layouts/base.twig" %}
{% set page_title = 'Exchange Rates Providers' %}

{% block content %}
    <script>
        window.providersCapabilities = {
            can_create: {{ capabilities.can_create ? 'true' : 'false' }},
            can_update: {{ capabilities.can_update ? 'true' : 'false' }},
            can_active: {{ capabilities.can_active ? 'true' : 'false' }},
            can_update_sort: {{ capabilities.can_update_sort ? 'true' : 'false' }},
            can_delete: {{ capabilities.can_delete ? 'true' : 'false' }},
            endpoints: {
                query: '{{ ui.adminUrl }}exchange-rates/providers/query',
                create: '{{ ui.adminUrl }}exchange-rates/providers/create',
                update: '{{ ui.adminUrl }}exchange-rates/providers/update',
                set_active: '{{ ui.adminUrl }}exchange-rates/providers/set-active',
                update_sort: '{{ ui.adminUrl }}exchange-rates/providers/update-sort',
                delete: '{{ ui.adminUrl }}exchange-rates/providers/delete'
            }
        };
    </script>

    <div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
        <div class="sm:flex sm:justify-between sm:items-center mb-8">
            <div class="mb-4 sm:mb-0">
                <h1 class="text-2xl md:text-3xl text-slate-800 dark:text-slate-100 font-bold">Exchange Rates Providers ✨</h1>
            </div>
            <div class="grid grid-flow-col sm:auto-cols-max justify-start sm:justify-end gap-2">
                {% if capabilities.can_create %}
                    <button class="btn bg-indigo-500 hover:bg-indigo-600 text-white" id="providers-create-btn">
                        <svg class="w-4 h-4 fill-current opacity-50 shrink-0" viewBox="0 0 16 16">
                            <path d="M15 7H9V1c0-.6-.4-1-1-1S7 .4 7 1v6H1c-.6 0-1 .4-1 1s.4 1 1 1h6v6c0 .6.4 1 1 1s1-.4 1-1V9h6c.6 0 1-.4 1-1s-.4-1-1-1z" />
                        </svg>
                        <span class="hidden xs:block ml-2">Create Provider</span>
                    </button>
                {% endif %}
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 shadow-lg rounded-sm border border-slate-200 dark:border-slate-700 relative">
            <header class="px-5 py-4 border-b border-slate-100 dark:border-slate-700">
                <h2 class="font-semibold text-slate-800 dark:text-slate-100">All Providers <span class="text-slate-400 dark:text-slate-500 font-medium" id="providers-total-count">0</span></h2>
            </header>
            <div x-data="providersTableContainer">
                <div class="overflow-x-auto">
                    <table class="table-auto w-full dark:text-slate-300" id="providers-table">
                        <thead class="text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-900/20 border-t border-b border-slate-200 dark:border-slate-700">
                            <tr>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Display Order</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Code</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Name</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-center">Status</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-right">Actions</div></th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-slate-200 dark:divide-slate-700" id="providers-table-body">
                            <!-- Rows rendered by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Provider Modal -->
    <div id="provider-modal" class="fixed inset-0 z-50 hidden bg-slate-900 bg-opacity-50 transition-opacity flex items-center justify-center">
        <div class="bg-white dark:bg-slate-800 rounded shadow-lg overflow-hidden w-full max-w-lg mx-4">
            <div class="px-5 py-3 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
                <h3 class="font-semibold text-slate-800 dark:text-slate-100" id="provider-modal-title">Provider</h3>
                <button class="text-slate-400 hover:text-slate-500" id="provider-modal-close">&times;</button>
            </div>
            <div class="px-5 py-4">
                <div id="provider-modal-error" class="hidden mb-4 p-3 bg-rose-100 text-rose-600 rounded"></div>
                <form id="provider-form">
                    <input type="hidden" id="provider-id" name="id">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium mb-1" for="provider-code">Code</label>
                            <input id="provider-code" name="code" class="form-input w-full" type="text" />
                            <p class="text-xs text-slate-500 mt-1" id="provider-code-help">Code is immutable after creation.</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1" for="provider-name">Name</label>
                            <input id="provider-name" name="name" class="form-input w-full" type="text" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1" for="provider-description">Description</label>
                            <textarea id="provider-description" name="description" class="form-textarea w-full" rows="3"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="px-5 py-4 border-t border-slate-200 dark:border-slate-700 flex justify-end">
                <button class="btn-sm border-slate-200 hover:border-slate-300 text-slate-600 mr-2" id="provider-modal-cancel">Cancel</button>
                <button class="btn-sm bg-indigo-500 hover:bg-indigo-600 text-white" id="provider-modal-save">Save</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/exchange_rates/providers-with-components-v2.js') }}"></script>
{% endblock %}
