{% extends "layouts/base.twig" %}
{% set page_title = 'Exchange Rates' %}

{% block content %}
    <script>
        window.ratesCapabilities = {
            can_create: {{ capabilities.can_create ? 'true' : 'false' }},
            can_update: {{ capabilities.can_update ? 'true' : 'false' }},
            can_active: {{ capabilities.can_active ? 'true' : 'false' }},
            can_update_sort: {{ capabilities.can_update_sort ? 'true' : 'false' }},
            can_delete: {{ capabilities.can_delete ? 'true' : 'false' }},
            can_view_history: {{ capabilities.can_view_history ? 'true' : 'false' }},
            endpoints: {
                query: '{{ ui.adminUrl }}exchange-rates/rates/query',
                create: '{{ ui.adminUrl }}exchange-rates/rates/create',
                update: '{{ ui.adminUrl }}exchange-rates/rates/update',
                set_active: '{{ ui.adminUrl }}exchange-rates/rates/set-active',
                update_sort: '{{ ui.adminUrl }}exchange-rates/rates/update-sort',
                delete: '{{ ui.adminUrl }}exchange-rates/rates/delete',
                history: '{{ ui.adminUrl }}exchange-rates/rates/history/query',
                providers_dropdown: '{{ ui.adminUrl }}exchange-rates/providers/dropdown'
            }
        };
    </script>

    <div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
        <div class="sm:flex sm:justify-between sm:items-center mb-8">
            <div class="mb-4 sm:mb-0">
                <h1 class="text-2xl md:text-3xl text-slate-800 dark:text-slate-100 font-bold">Exchange Rates ✨</h1>
            </div>
            <div class="grid grid-flow-col sm:auto-cols-max justify-start sm:justify-end gap-2">
                {% if capabilities.can_create %}
                    <button class="btn bg-indigo-500 hover:bg-indigo-600 text-white" id="rates-create-btn">
                        <svg class="w-4 h-4 fill-current opacity-50 shrink-0" viewBox="0 0 16 16">
                            <path d="M15 7H9V1c0-.6-.4-1-1-1S7 .4 7 1v6H1c-.6 0-1 .4-1 1s.4 1 1 1h6v6c0 .6.4 1 1 1s1-.4 1-1V9h6c.6 0 1-.4 1-1s-.4-1-1-1z" />
                        </svg>
                        <span class="hidden xs:block ml-2">Create Rate</span>
                    </button>
                {% endif %}
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 shadow-lg rounded-sm border border-slate-200 dark:border-slate-700 relative">
            <header class="px-5 py-4 border-b border-slate-100 dark:border-slate-700">
                <h2 class="font-semibold text-slate-800 dark:text-slate-100">All Rates <span class="text-slate-400 dark:text-slate-500 font-medium" id="rates-total-count">0</span></h2>
            </header>
            <div x-data="ratesTableContainer">
                <div class="overflow-x-auto">
                    <table class="table-auto w-full dark:text-slate-300" id="rates-table">
                        <thead class="text-xs font-semibold uppercase text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-900/20 border-t border-b border-slate-200 dark:border-slate-700">
                            <tr>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Provider</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Base</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Target</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-left">Rate</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-center">Status</div></th>
                                <th class="px-2 first:pl-5 last:pr-5 py-3 whitespace-nowrap"><div class="font-semibold text-right">Actions</div></th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-slate-200 dark:divide-slate-700" id="rates-table-body">
                            <!-- Rows rendered by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

    <script src="{{ asset('assets/maatify/admin-kernel/js/pages/exchange_rates/rates-with-components-v2.js') }}"></script>
