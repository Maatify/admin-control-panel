# =========================================================
# STORAGE
# =========================================================

# Driver: local | do_spaces
STORAGE_DRIVER=local

# ---------------------------------------------------------
# Local Storage (used when STORAGE_DRIVER=local)
# ---------------------------------------------------------

# Leave empty to use default: {APP_ROOT}/public/images
LOCAL_BASE_PATH=
LOCAL_BASE_URL=/images

# ---------------------------------------------------------
# DigitalOcean Spaces (used when STORAGE_DRIVER=do_spaces)
# ---------------------------------------------------------

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_BUCKET=
DO_SPACES_CDN_URL=https://your-bucket.fra1.cdn.digitaloceanspaces.com

# public-read | private
DO_SPACES_ACL=public-read
