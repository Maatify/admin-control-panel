{
  "name": "maatify/settings",
  "description": "Reusable settings module for Maatify applications.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "maatify",
    "settings",
    "configuration",
    "runtime-settings",
    "admin-settings",
    "key-value",
    "application-config",
    "feature-flags",
    "php",
    "pdo"
  ],
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "psr/container": "^1.1|^2.0"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\Settings\\": "src/"
    }
  },

  "require-dev": {
    "ext-pdo_sqlite": "*",
    "php-di/php-di": "^7.0",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "autoload-dev": {
    "psr-4": {
      "Maatify\\Settings\\Tests\\": "tests/"
    }
  },
  "suggest": {
    "php-di/php-di": "Required only if you use the optional SettingsBindings::register(...) helper."
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "homepage": "https://github.com/Maatify/settings",
  "support": {
    "source": "https://github.com/Maatify/settings",
    "issues": "https://github.com/Maatify/settings/issues"
  }
}