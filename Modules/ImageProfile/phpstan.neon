includes:
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:

    # -------------------------------------------------------------------------
    # Analysis level: max
    # -------------------------------------------------------------------------
    level: max

    # -------------------------------------------------------------------------
    # Source paths
    # -------------------------------------------------------------------------
    paths:
        - src

    # -------------------------------------------------------------------------
    # Exclusions
    # -------------------------------------------------------------------------
    excludePaths:
        - vendor
        - tests
        - build

    # -------------------------------------------------------------------------
    # Strict behaviour
    # -------------------------------------------------------------------------
    checkMissingIterableValueType: true
    checkGenericClassInNonGenericObjectType: true
    reportUnmatchedIgnoredErrors: true

    # -------------------------------------------------------------------------
    # PHP version
    # Must match the minimum requirement declared in composer.json (8.2).
    # -------------------------------------------------------------------------
    phpVersion: 80200

    # -------------------------------------------------------------------------
    # Bootstrap
    # -------------------------------------------------------------------------
    bootstrapFiles:
        - vendor/autoload.php