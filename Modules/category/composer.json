{
  "name": "maatify/category",
  "description": "Standalone Category Module — hierarchical category management with PDO & Slim-ready DI bindings",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "maatify/exceptions": "^1.0",
    "psr/container": "^1.1|^2.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpstan/phpstan-strict-rules": "^1.6",
    "php-di/php-di": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\Category\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maatify\\Category\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}

