{
  "name": "maatify/admin-control-panel",
  "type": "project",
  "description": "Runnable Admin Control Panel",
  "license": "MIT",

  "require": {
    "php": "^8.2",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-fileinfo": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-readline": "*",
    "ext-redis": "*",
    "ezyang/htmlpurifier": "^4.19",
    "maatify/crypto": "^1.0",
    "maatify/event-logging": "^1.0",
    "maatify/exceptions": "^1.0",
    "maatify/persistence": "^1.0",
    "maatify/psr-logger": "^1.0",
    "maatify/shared-common": "^1.0",
    "php-di/php-di": "^7.0",
    "phpmailer/phpmailer": "^7.0",
    "pragmarx/google2fa": "^8.0",
    "ramsey/uuid": "^4.9",
    "respect/validation": "^2.4",
    "slim/psr7": "^1.8",
    "slim/slim": "^4.15",
    "slim/twig-view": "^3.4",
    "vlucas/phpdotenv": "^5.5"
  },

  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "aws/aws-sdk-php": "^3.0"
  },

  "autoload": {
    "psr-4": {
      "Maatify\\AdminKernel\\": "app/Modules/AdminKernel/",
      "Maatify\\EmailDelivery\\": "Modules/EmailDelivery",
      "Maatify\\InputNormalization\\": "Modules/InputNormalization",
      "Maatify\\Validation\\": "Modules/Validation",
      "Maatify\\RateLimiter\\": "Modules/RateLimiter",
      "Maatify\\AbuseProtection\\": "Modules/AbuseProtection",
      "Maatify\\I18n\\": "Modules/I18n",
      "Maatify\\AppSettings\\": "Modules/AppSettings",
      "Maatify\\LanguageCore\\": "Modules/LanguageCore",
      "Maatify\\ContentDocuments\\": "Modules/ContentDocuments",
      "Maatify\\Verification\\": "Modules/Verification",
      "Maatify\\Currency\\": "Modules/currency/src",
      "Maatify\\CurrencySlim\\": "Modules/CurrencySlim/src",
      "Maatify\\Storage\\": "Modules/Storage/src",
      "Maatify\\ImageProfile\\": "Modules/ImageProfile/src",
      "Maatify\\ImageProfileLegacy\\": "Modules/ImageProfileLegacy/src",
      "Maatify\\WebsiteUiTheme\\": "Modules/WebsiteUiTheme/src",
      "Maatify\\ExchangeRates\\": "Modules/ExchangeRates/src",
      "Maatify\\ExchangeRatesSlim\\": "Modules/ExchangeRatesSlim/src",
      "Maatify\\Geo\\": "Modules/geo/src",
      "Maatify\\GeoSlim\\": "Modules/GeoSlim/src",
      "Maatify\\Settings\\": "Modules/Settings/src",
      "Maatify\\SettingsSlim\\": "Modules/SettingsSlim/src"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Maatify\\Geo\\Tests\\": "Modules/geo/tests/"
    }
  },

  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse app Modules --level=max",
    "Permission Linter": "php tools/permission_linter.php"
  },

  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },

  "minimum-stability": "stable",
  "prefer-stable": true
}
